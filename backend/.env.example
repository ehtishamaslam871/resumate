# MongoDB Configuration
MONGODB_URI=mongodb+srv://ehtishamaslam:XQdOk4ekHqk1ezTB@resumate.stg70eh.mongodb.net/resumate?retryWrites=true&w=majority&appName=resumate
MONGODB_FALLBACK_URI=mongodb://127.0.0.1:27017/resumate

# Server Configuration
PORT=5000
NODE_ENV=development
BASE_URL=http://localhost:5001
CLIENT_URL=http://localhost:5173

# Clerk Authentication (Preferred)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this
JWT_EXPIRE=7d

# Email Configuration
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@resumate.com

# AWS S3 Configuration (Optional)
CLOUD_STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# Google Cloud Storage Configuration (Optional)
# CLOUD_STORAGE_PROVIDER=gcs
# GCS_PROJECT_ID=your-project-id
# GCS_KEY_FILE=/path/to/keyfile.json
# GCS_BUCKET=your-bucket-name

# Frontend Configuration
# CLIENT_URL is defined above in Server Configuration

# Redis Configuration (Optional, for caching)
REDIS_URL=redis://localhost:6379

# Application Configuration
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=pdf,doc,docx

# AI Provider Configuration
# AI_PROVIDER=auto -> use OpenAI when OPENAI_API_KEY is present, else local model server
# AI_PROVIDER=openai -> force OpenAI
# AI_PROVIDER=local -> force local model server
AI_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL_INTERVIEW_GENERATION=gpt-4.1-mini
OPENAI_MODEL_INTERVIEW_EVALUATION=gpt-4.1
OPENAI_MODEL_INTERVIEW_FEEDBACK=gpt-4.1
